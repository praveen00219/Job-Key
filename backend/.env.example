# JobKey API configuration — copy to .env and adjust. Every value has a dev
# default in app/config.py; production MUST override JWT_SECRET and DATABASE_URL.

# SQLite (dev default) or Postgres, e.g. postgresql+psycopg://user:pass@host:5432/jobkey
DATABASE_URL=sqlite:///./jobkey.db

# Sign JWTs — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
REFRESH_EXPIRES_DAYS=14
VERIFY_TOKEN_EXPIRES_HOURS=48
RESET_TOKEN_EXPIRES_MINUTES=60

# Dev conveniences (dev-token endpoint, console "email" delivery).
# MUST be false in production.
DEV_MODE=true

# PRD login-lockout rule
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
