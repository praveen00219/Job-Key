{
  "manifest_version": 3,
  "name": "JobKey for LinkedIn",
  "version": "0.1.0",
  "description": "Save LinkedIn candidates to your JobKey CRM and submit them to vacancies without leaving the page.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobKey"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
